# Copy to .env.local for local dev. For SPONSORED gas to work, set these in
# VERCEL too (the MOSS relay calls /porto/merchant server-side, not localhost),
# and point NEXT_PUBLIC_SPONSOR_URL at the deployed domain. Comments must be on
# their OWN lines — a trailing "# ..." after a value can be parsed into the value.

# --- Merchant / paymaster (server-only — NEVER prefix the key with NEXT_PUBLIC) ---
MERCHANT_ADDRESS=0xYourMerchantAccount
MERCHANT_PRIVATE_KEY=0xYourMerchantPrivateKey
# Set only if Moss says sponsorship is rejected (MegaETH Porto relay URL):
# MERCHANT_RELAY_URL=https://...

# --- Dripper operator (server-only — signs UsdmDripper.drip) ---
OPERATOR_PRIVATE_KEY=0xYourDripperOperatorKey
# Optional override; defaults to the deployed dripper:
# DRIPPER_ADDRESS=0x176E9A0B7a7911d49F70eB42d76b29157cd6cBc2

# --- Client-readable sponsor config (NEXT_PUBLIC) ---
NEXT_PUBLIC_SPONSOR_URL=https://YOUR-APP.vercel.app/porto/merchant
NEXT_PUBLIC_SPONSOR_TOKEN=usdm
# app-only (default) | explicit | everything (testing-only)
# NEXT_PUBLIC_SPONSOR_MODE=app-only
